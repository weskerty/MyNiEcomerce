{
  "id": "/cheagana",
  "name": "Che Agana 😻",
  "short_name": "Che Agana",
  "description": "Tienda Facil en Paraguay.",
  "lang": "es-PY",
  "dir": "ltr",
  "start_url": "/#web/otros/Archivos/HTML/centralPage.html",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "orientation": "any",
  "background_color": "#000000",
  "theme_color": "#000000",
  "categories": ["shopping", "lifestyle"],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "handle_links": "preferred",
  "icons": [
    {
      "src": "web/favicon.ico",
      "sizes": "48x48",
      "type": "image/x-icon"
    },
    {
      "src": "web/otros/Archivos/Imagenes/Permanente/ICONS/ICON-APP.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "web/otros/Archivos/Imagenes/Permanente/ICONS/ICON-APP.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable any"
    }
  ],
"shortcuts": [
  {
    "name": "Actividades",
    "url": "/#web/otros/Archivos/HTML/Grupos.html",
    "icons": [
      {
        "src": "web/otros/Archivos/Imagenes/Permanente/ICONS/CatSmile.png",
        "sizes": "96x96",
        "type": "image/png"
      }
    ]
  },
  {
    "name": "Blogs",
    "url": "/#web/blogs.html",
    "icons": [
      {
        "src": "web/otros/Archivos/Imagenes/Permanente/ICONS/Blogs.png",
        "sizes": "96x96",
        "type": "image/png"
      }
    ]
  },
  {
    "name": "Tienda",
    "url": "/#web/es.html",
    "icons": [
      {
        "src": "web/otros/Archivos/Imagenes/Permanente/ICONS/Cesta.png",
        "sizes": "96x96",
        "type": "image/png"
      }
    ]
  },
  {
    "name": "Juegos y Apps",
    "url": "/#web/otros/Archivos/HTML/apps.html",
    "icons": [
      {
        "src": "web/otros/Archivos/Imagenes/Permanente/ICONS/Apps.png",
        "sizes": "96x96",
        "type": "image/png"
      }
    ]
  }
],
  "file_handlers": [
    {
      "action": "/open-file",
      "accept": {
        "image/*": [".jpg", ".jpeg", ".png", ".webp", ".avif", ".gif"],
        "application/pdf": [".pdf"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+cheagana",
      "url": "/?protocol=%s"
    }
  ],
  "share_target": {
    "action": "/_share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": ["image/*", "video/*", "audio/*", "application/pdf", "application/epub", "*/*"]
        }
      ]
    }
  }
}
